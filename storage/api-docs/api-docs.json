        "/api/v1/dashboard/stats": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Aggregate KPIs and 12-month borrowing trend",
                "operationId": "00464eac0b2daa2b7dfd173ce52781f0",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiEnvelope"
                                        },
                                        {
                                            "properties": {
                                                "data": {
                                                    "properties": {
                                                        "total_stock": {
                                                            "type": "integer"
                                                        },
                                                        "borrowed_count": {
                                                            "type": "integer"
                                                        },
                                                        "available_stock": {
                                                            "type": "integer"
                                                        },
                                                        "total_categories": {
                                                            "type": "integer"
                                                        },
                                                        "total_products": {
                                                            "type": "integer"
                                                        },
                                                        "low_stock_products": {
                                                            "type": "integer"
                                                        },
                                                        "active_borrowings": {
                                                            "type": "integer"
                                                        },
                                                        "overdue_borrowings": {
                                                            "type": "integer"
                                                        },
                                                        "monthly_trends": {
                                                            "type": "array",
                                                            "items": {
                                                                "properties": {
                                                                    "month": {
                                                                        "type": "string",
                                                                        "example": "2026-07"
                                                                    },
                                                                    "total": {
                                                                        "type": "integer"
                                                                    }
                                                                },
                                                                "type": "object"
                                                            }
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
