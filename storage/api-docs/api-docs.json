            "post": {
                "tags": [
                    "Products"
                ],
                "summary": "Create a product",
                "operationId": "acaa0d3fdc74fd4b534e70fc016cf7f1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "code",
                                    "name",
                                    "category_id",
                                    "stock",
                                    "condition"
                                ],
                                "properties": {
                                    "code": {
                                        "type": "string",
                                        "example": "INV-ELE-007"
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "Monitor LG 24 inch"
                                    },
                                    "category_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "stock": {
                                        "type": "integer",
                                        "example": 10,
                                        "minimum": 0
                                    },
                                    "location": {
                                        "type": "string",
                                        "example": "Gudang IT Lt. 2",
                                        "nullable": true
                                    },
                                    "condition": {
                                        "type": "string",
                                        "enum": [
                                            "baik",
                                            "rusak_ringan",
                                            "rusak_berat"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiEnvelope"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
